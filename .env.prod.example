# Copy to .env and fill in before running the production stack:
#   cp .env.prod.example .env
#   docker compose -f docker-compose.prod.yml up -d --build

# Public base URL rendered into short links (scheme + host, no trailing slash).
APP_BASE_URL=https://links.example.com

# Long random secrets — generate each with: openssl rand -hex 32
POSTGRES_PASSWORD=
IP_HASH_SALT=

# Public HTTP port nginx listens on.
WEB_PORT=80

# Demo playground knobs (defaults shown; uncomment to override).
# SEED_DEMO_TENANT=true      # set false to disable the keyless playground
# DEMO_MAX_LINK_TTL=24h      # demo links never live longer than this
# DEMO_CLEANUP_INTERVAL=1h   # janitor sweep cadence
# DEMO_RETENTION=24h         # grace before dead demo links are hard-deleted
# RATE_LIMIT_REQUESTS=60     # per-tenant requests per window
# RATE_LIMIT_WINDOW=1m
